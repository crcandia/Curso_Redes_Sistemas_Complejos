---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign indexed_pages = site.pages | where_exp: "item", "item.sitemap != false" | sort: "url" -%}
{%- for item in indexed_pages %}
  {%- unless item.url contains '/assets/' %}
  <url>
    <loc>{{ item.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>{{ item.changefreq | default: 'monthly' }}</changefreq>
    <priority>{{ item.sitemap_priority | default: '0.60' }}</priority>
  </url>
  {%- endunless %}
{%- endfor %}
</urlset>
